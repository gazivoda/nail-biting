# Google OAuth (nail-habit dedicated credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Production: your app domain (e.g. https://stopbiting.today)
# Dev: http://localhost:5173
# Desktop (Electron): http://localhost:3000 (the app loads from the embedded Express server)
APP_URL=http://localhost:5173

PORT=3000

# Paddle credentials (from Paddle Dashboard)
# production or sandbox — used by both server (API base URL) and frontend (Paddle.js)
VITE_PADDLE_ENV=production
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_PRICE_ID_MONTHLY=
VITE_PADDLE_PRICE_ID_YEARLY=

# Resend transactional email (get key at resend.com)
RESEND_API_KEY=

# Formspree contact form ID (the part after /f/ in the formspree endpoint)
VITE_FORMSPREE_FORM_ID=
